# Ollama ROCm Configuration Template
# Copy this file to .env and adjust for your system:
#   cp .env.example .env
#
# Or run setup.sh which will auto-detect and create .env for you.

# =============================================================================
# MODEL PERFORMANCE TUNING
# =============================================================================
# These settings directly affect model quality and responsiveness.
# Adjust based on your VRAM and use case.
#
# IMPORTANT: If models seem to forget context, ignore instructions, or give
# confused responses, increase OLLAMA_NUM_CTX first.

# Context window size (tokens) - CRITICAL for agentic/coding tasks
# This determines how much conversation history and instructions the model retains.
# Too low = model forgets context, ignores instructions, gives confused responses
#
# Recommended values:
#   16384  - Basic chat, limited VRAM
#   32768  - General purpose, good balance (default)
#   65536  - Agentic coding tasks, complex multi-step reasoning
#   131072 - Maximum context (requires significant VRAM, not all models support)
#
# Note: Higher values use more VRAM. If you get OOM errors, reduce this.
OLLAMA_NUM_CTX=32768

# GPU layer offloading
# -1 = offload all layers to GPU (recommended, fastest)
#  0 = CPU only (no GPU acceleration)
#  N = offload N layers to GPU (use if running out of VRAM)
OLLAMA_NUM_GPU=-1

# Request timeout in seconds (default: 120)
# Increase for:
#   - Complex reasoning models (deepseek-r1, qwq)
#   - Very long outputs
#   - Slow hardware
OLLAMA_REQUEST_TIMEOUT=300

# =============================================================================
# SYSTEM-SPECIFIC SETTINGS (you must configure these)
# =============================================================================

# Group IDs for GPU access
# Find yours with:
#   getent group video | cut -d: -f3
#   getent group render | cut -d: -f3
VIDEO_GROUP_ID=
RENDER_GROUP_ID=

# AMD GPU architecture override
# This tells ROCm how to handle your GPU. Use the correct value for your card:
#
#   GPU Family              | Cards                        | HSA Version
#   ------------------------|------------------------------|------------
#   Navi 31 (RDNA3)         | RX 7900 XTX/XT/GRE          | 11.0.0
#   Navi 32 (RDNA3)         | RX 7800 XT, RX 7700 XT      | 11.0.0
#   Navi 33 (RDNA3)         | RX 7600                      | 11.0.0
#   Navi 21 (RDNA2)         | RX 6900 XT, RX 6800 XT/6800 | 10.3.0
#   Navi 22 (RDNA2)         | RX 6700 XT                   | 10.3.0
#   Navi 23 (RDNA2)         | RX 6600 XT, RX 6600         | 10.3.0
#   Navi 10 (RDNA1)         | RX 5700 XT, RX 5700         | 10.1.0
#
# Find your GPU: lspci | grep -i vga
HSA_OVERRIDE_GFX_VERSION=11.0.0

# Container user ID and group ID
# The container runs as your user (not root) so files are owned by you
# Find yours with: id -u && id -g
OLLAMA_UID=1000
OLLAMA_GID=1000

# =============================================================================
# OLLAMA SETTINGS (adjust based on your VRAM and needs)
# =============================================================================

# How long to keep models loaded in VRAM after last request
# Examples: 5m, 30m, 1h, 0 (unload immediately)
OLLAMA_KEEP_ALIVE=10m

# Number of parallel requests to handle
# - 24GB VRAM (7900 XTX): 2-4 for 32B models, higher for smaller models
# - 16GB VRAM (7800 XT): 1-2 for 32B models
# - Reduce if you experience OOM errors
OLLAMA_NUM_PARALLEL=2

# Maximum models loaded in VRAM simultaneously
# Keep at 1 for large models (32B+), increase for smaller models
OLLAMA_MAX_LOADED_MODELS=1

# Enable flash attention (1=enabled, 0=disabled)
# Improves inference speed, recommended to keep enabled
OLLAMA_FLASH_ATTENTION=1

# =============================================================================
# PATHS
# =============================================================================

# Where Ollama stores models and data
# Default: ~/.ollama (models can be 20GB+ each, ensure sufficient disk space)
OLLAMA_DATA_DIR=${HOME}/.ollama

# =============================================================================
# VERSION PINNING (optional)
# =============================================================================

# Pin to a specific Ollama version instead of using latest
# Leave empty or set to "rocm" for latest ROCm version
# Find versions at: https://hub.docker.com/r/ollama/ollama/tags
# Example: rocm-0.3.6
# OLLAMA_VERSION=rocm
