# llama.cpp ROCm Configuration Template
# Copy this file to .env and adjust for your system:
#   cp .env.example .env
#
# Or run setup.sh which will auto-detect and create .env for you.

# =============================================================================
# SERVER SETTINGS
# =============================================================================
# These settings control the llama-server behavior.

# Server port
# Default: 8080
# If Ollama is also running, use a different port (e.g., 8081)
LLAMA_PORT=8080

# Context window size (tokens)
# This determines how much conversation history the model retains.
# Higher values = more VRAM usage, better for long conversations/coding
#
# Recommended values:
#   8192   - Limited VRAM, basic chat
#   16384  - Balanced, moderate VRAM
#   32768  - Good for coding tasks (default)
#   65536  - Agentic tasks, complex reasoning (needs significant VRAM)
#   131072 - Maximum context (very high VRAM, not all models support)
#
# Note: If you get OOM errors, reduce this value.
LLAMA_CONTEXT=32768

# Number of GPU layers to offload
# -1 = offload all layers to GPU (recommended, fastest)
#  0 = CPU only (no GPU acceleration)
#  N = offload N layers to GPU (partial offload, saves VRAM)
GPU_LAYERS=-1

# Number of parallel request slots
# Higher = more concurrent requests but more VRAM
# For 24GB VRAM (7900 XTX): 2-4 for 32B models
# For 16GB VRAM (7800 XT): 1-2 for 32B models
LLAMA_PARALLEL=2

# Batch size for prompt processing
# Higher = faster prompt processing but more VRAM
# Default: 512
LLAMA_BATCH_SIZE=512

# Number of CPU threads for inference
# Default: auto-detect (usually number of physical cores)
# Set explicitly if auto-detect doesn't work well
# LLAMA_THREADS=8

# =============================================================================
# GPU SETTINGS
# =============================================================================
# These settings control how ROCm/HIP interacts with your AMD GPU.

# GPU target architecture
# Detected automatically by setup.sh, but can be overridden here.
#
#   GPU Family              | Cards                        | Target
#   ------------------------|------------------------------|----------
#   Navi 31 (RDNA3)         | RX 7900 XTX/XT/GRE          | gfx1100
#   Navi 32 (RDNA3)         | RX 7800 XT, RX 7700 XT      | gfx1101
#   Navi 33 (RDNA3)         | RX 7600                      | gfx1102
#   Navi 21 (RDNA2)         | RX 6900 XT, RX 6800 XT/6800 | gfx1030
#   Navi 22 (RDNA2)         | RX 6700 XT                   | gfx1031
#   Navi 23 (RDNA2)         | RX 6600 XT, RX 6600         | gfx1032
#   Navi 10 (RDNA1)         | RX 5700 XT, RX 5700         | gfx1010
#   Vega 20                 | Radeon VII                   | gfx906
#   Vega 10                 | RX Vega 64/56               | gfx900
#
# Find your GPU: lspci | grep -i vga
GPU_TARGET=gfx1100

# HSA override for GPU compatibility
# Required for some GPUs that aren't officially supported by ROCm.
#
# Common values:
#   11.0.0 - RDNA3 (RX 7000 series)
#   10.3.0 - RDNA2 (RX 6000 series)
#   10.1.0 - RDNA1 (RX 5000 series)
#   9.0.6  - Vega 20 (Radeon VII)
#   9.0.0  - Vega 10 (RX Vega 64/56)
HSA_OVERRIDE_GFX_VERSION=11.0.0

# =============================================================================
# PATHS
# =============================================================================
# Default paths are relative to the script directory.

# llama.cpp repository directory
# LLAMA_CPP_DIR=/path/to/llama.cpp

# Models directory (where GGUF files are stored)
# MODELS_DIR=/path/to/models

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Advanced settings for performance optimization.

# Enable flash attention (improves inference speed)
# 1 = enabled (default), 0 = disabled
LLAMA_FLASH_ATTENTION=1

# Memory-mapped model loading
# 1 = enabled (default, faster loading)
# 0 = disabled (may be needed on some systems)
LLAMA_MMAP=1

# Memory locking (prevents swapping)
# 1 = enabled (can improve performance if you have enough RAM)
# 0 = disabled (default)
LLAMA_MLOCK=0

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
# LLAMA_LOG_LEVEL=info

# Log file (leave empty for stdout)
# LLAMA_LOG_FILE=/var/log/llama-server.log
