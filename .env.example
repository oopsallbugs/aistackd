# llama.cpp Configuration Example
# Copy to .env and edit, or run setup.sh to generate automatically.
# Model settings (context, output limits) are in models.conf.

# =============================================================================
# GPU CONFIGURATION
# =============================================================================

# GPU vendor (set by setup.sh: nvidia, amd, or cpu)
GPU_VENDOR=amd

# AMD ROCm Settings (Linux only)
# -----------------------------------------------------------------------------
# GPU architecture target (set by setup.sh, used at compile time)
GPU_TARGET=gfx1100

# HSA override for GPU compatibility
HSA_OVERRIDE_GFX_VERSION=11.0.0

# Which GPU to use at runtime (for multi-GPU systems)
# Run 'rocm-smi --showbus' to see GPU IDs and their PCI addresses
# GPU_ID=0   # First GPU
# GPU_ID=1   # Second GPU
#
# NOTE: All GPUs must share the same architecture (GPU_TARGET).
# If you have mixed GPU architectures, you must rebuild llama.cpp
# (./setup.sh --force-rebuild) each time you switch between them.

# NVIDIA CUDA Settings (Linux only)
# -----------------------------------------------------------------------------
# For NVIDIA GPUs, GPU_VENDOR=nvidia is all that's needed.
# CUDA device selection (for multi-GPU systems):
# CUDA_VISIBLE_DEVICES=0   # First GPU
# CUDA_VISIBLE_DEVICES=1   # Second GPU
# CUDA_VISIBLE_DEVICES=0,1 # Both GPUs

# GPU layers to offload (99 = all layers)
# Reduce for partial offload if model doesn't fit in VRAM
GPU_LAYERS=99

# =============================================================================
# SERVER SETTINGS
# =============================================================================

# Server port
# Use 11434 for OpenAI-compatible API (Frigate, Home Assistant, etc.)
LLAMA_PORT=8080

# Server bind address
# 127.0.0.1 = localhost only
# 0.0.0.0   = all interfaces (for network/container access)
LLAMA_HOST=127.0.0.1

# =============================================================================
# REMOTE LLM SERVER (for OpenHands and other clients)
# =============================================================================
# If you're running llama.cpp on a separate GPU server, configure these
# settings for clients like OpenHands to connect remotely.

# Remote LLM server URL (leave empty if running locally)
# REMOTE_LLM_URL=http://gpu-server.local:8080

# For OpenHands: The LLM server endpoint it should connect to
# If REMOTE_LLM_URL is set, OpenHands will use that
# Otherwise, it defaults to http://127.0.0.1:${LLAMA_PORT}
# OPENHANDS_LLM_BASE_URL=http://127.0.0.1:8080

# =============================================================================
# PATHS
# =============================================================================

# llama.cpp directory (absolute path, set by setup.sh)
LLAMA_CPP_DIR=/path/to/llama-cpp-setup/llama.cpp

# Models directory (absolute path, set by setup.sh)
MODELS_DIR=/path/to/llama-cpp-setup/models

# =============================================================================
# RAG SETTINGS
# =============================================================================

# Auto-start RAG server with llama.cpp (true/false)
# Set to false to disable RAG auto-start, or use --no-rag flag
AUTO_START_RAG_SERVER=true

# RAG server port
RAG_PORT=8081

# SearXNG port (for web search)
SEARXNG_PORT=8888

# =============================================================================
# OPENHANDS SETTINGS
# =============================================================================

# OpenHands workspace directory (absolute path)
# This is where OpenHands will have access to for agentic tasks
# OPENHANDS_WORKSPACE=/home/user/projects

# OpenHands version (docker image tag)
OPENHANDS_VERSION=1.3.0

# OpenHands web UI port
OPENHANDS_PORT=3000

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Log file path (empty = stdout)
# LOG_FILE=/var/log/llama-server.log

# Vision model multimodal projector (usually auto-detected)
# MMPROJ_PATH=/path/to/mmproj.gguf

# =============================================================================
# MACOS ONLY (set by setup-macos.sh for reference)
# =============================================================================

# CHIP_NAME=Apple M2 Pro
# MEMORY_GB=32
